{
  "name": "kid-tracker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "db:create": "wrangler d1 create kid-tracker-db",
    "db:init": "wrangler d1 execute kid-tracker-db --file=schema.sql",
    "setup": "npm run db:create && npm run db:init && npm run deploy"
  },
  "devDependencies": {
    "wrangler": "^3.0.0"
  }
}
