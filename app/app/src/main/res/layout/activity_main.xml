<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#060612"
    android:padding="24dp"
    android:gravity="center"
    android:layoutDirection="ltr"
    android:textDirection="ltr">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title"
        android:textColor="#00e5ff"
        android:textSize="36sp"
        android:textStyle="bold"
        android:letterSpacing="0.15"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/subtitle"
        android:textColor="#7c4dff"
        android:textSize="10sp"
        android:textStyle="bold"
        android:letterSpacing="0.3"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/made_by"
        android:textColor="#334455"
        android:textSize="9sp"
        android:layout_marginBottom="24dp" />

    <LinearLayout
        android:id="@+id/setupSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/set_code"
            android:textColor="#667788"
            android:textSize="14sp"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/same_code_hint"
            android:textColor="#556677"
            android:textSize="12sp"
            android:layout_marginBottom="32dp" />

        <LinearLayout
            android:id="@+id/codeSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="28dp">

            <EditText android:id="@+id/code1" android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1" android:layout_marginEnd="6dp" android:gravity="center" android:textSize="24sp" android:textStyle="bold" android:textColor="#00e5ff" android:background="@drawable/code_input_bg" android:inputType="number" android:maxLength="1" />
            <EditText android:id="@+id/code2" android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1" android:layout_marginEnd="6dp" android:gravity="center" android:textSize="24sp" android:textStyle="bold" android:textColor="#00e5ff" android:background="@drawable/code_input_bg" android:inputType="number" android:maxLength="1" />
            <EditText android:id="@+id/code3" android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1" android:layout_marginEnd="6dp" android:gravity="center" android:textSize="24sp" android:textStyle="bold" android:textColor="#00e5ff" android:background="@drawable/code_input_bg" android:inputType="number" android:maxLength="1" />
            <EditText android:id="@+id/code4" android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1" android:layout_marginEnd="6dp" android:gravity="center" android:textSize="24sp" android:textStyle="bold" android:textColor="#00e5ff" android:background="@drawable/code_input_bg" android:inputType="number" android:maxLength="1" />
            <EditText android:id="@+id/code5" android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1" android:layout_marginEnd="6dp" android:gravity="center" android:textSize="24sp" android:textStyle="bold" android:textColor="#00e5ff" android:background="@drawable/code_input_bg" android:inputType="number" android:maxLength="1" />
            <EditText android:id="@+id/code6" android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1" android:gravity="center" android:textSize="24sp" android:textStyle="bold" android:textColor="#00e5ff" android:background="@drawable/code_input_bg" android:inputType="number" android:maxLength="1" />

        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/connectButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/start_tracking"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#060612"
            app:backgroundTint="#00e5ff"
            app:cornerRadius="12dp"
            android:enabled="false" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/bg_note"
            android:textColor="#334455"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_marginTop="24dp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/activeSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/active_status"
            android:textColor="#00ff88"
            android:textSize="48sp"
            android:textStyle="bold"
            android:letterSpacing="0.2"
            android:layout_marginBottom="8dp" />

        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/neon_dot"
            android:layout_marginBottom="16dp" />

        <TextView
            android:id="@+id/activeCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#556677"
            android:textSize="13sp"
            android:layout_marginBottom="32dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/stopButton"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/stop_tracking"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#fff"
            app:backgroundTint="#ff1744"
            app:cornerRadius="12dp" />

    </LinearLayout>

</LinearLayout>
