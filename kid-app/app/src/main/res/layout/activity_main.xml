<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0a0a1a"
    android:padding="24dp"
    android:gravity="center"
    android:supportsRtl="true">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title"
        android:textColor="#e94560"
        android:textSize="32sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/set_code"
        android:textColor="#aaaaaa"
        android:textSize="14sp"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/same_code_hint"
        android:textColor="#888888"
        android:textSize="12sp"
        android:layout_marginBottom="40dp" />

    <LinearLayout
        android:id="@+id/codeSection"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="32dp">

        <EditText
            android:id="@+id/code1"
            android:layout_width="52dp"
            android:layout_height="64dp"
            android:gravity="center"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#e94560"
            android:background="@drawable/code_input_bg"
            android:inputType="number"
            android:maxLength="1"
            android:layout_marginEnd="8dp" />

        <EditText
            android:id="@+id/code2"
            android:layout_width="52dp"
            android:layout_height="64dp"
            android:gravity="center"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#e94560"
            android:background="@drawable/code_input_bg"
            android:inputType="number"
            android:maxLength="1"
            android:layout_marginEnd="8dp" />

        <EditText
            android:id="@+id/code3"
            android:layout_width="52dp"
            android:layout_height="64dp"
            android:gravity="center"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#e94560"
            android:background="@drawable/code_input_bg"
            android:inputType="number"
            android:maxLength="1"
            android:layout_marginEnd="8dp" />

        <EditText
            android:id="@+id/code4"
            android:layout_width="52dp"
            android:layout_height="64dp"
            android:gravity="center"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#e94560"
            android:background="@drawable/code_input_bg"
            android:inputType="number"
            android:maxLength="1"
            android:layout_marginEnd="8dp" />

        <EditText
            android:id="@+id/code5"
            android:layout_width="52dp"
            android:layout_height="64dp"
            android:gravity="center"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#e94560"
            android:background="@drawable/code_input_bg"
            android:inputType="number"
            android:maxLength="1"
            android:layout_marginEnd="8dp" />

        <EditText
            android:id="@+id/code6"
            android:layout_width="52dp"
            android:layout_height="64dp"
            android:gravity="center"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#e94560"
            android:background="@drawable/code_input_bg"
            android:inputType="number"
            android:maxLength="1" />

    </LinearLayout>

    <EditText
        android:id="@+id/apiUrlInput"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:hint="https://tsp.omaromartest12.workers.dev"
        android:textColorHint="#555555"
        android:textColor="#ccc"
        android:textSize="13sp"
        android:background="@drawable/code_input_bg"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:inputType="textUri"
        android:singleLine="true"
        android:layout_marginBottom="20dp" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/connectButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="@string/start_tracking"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="#e94560"
        app:cornerRadius="12dp"
        android:enabled="false" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/bg_note"
        android:textColor="#666666"
        android:textSize="11sp"
        android:gravity="center"
        android:layout_marginTop="24dp" />

</LinearLayout>
